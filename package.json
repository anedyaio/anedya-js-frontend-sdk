    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "node tests/test.mjs"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "IoT",
    "Anedya",
    "SDK",
    "JavaScript",
