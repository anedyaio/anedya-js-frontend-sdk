{
  "name": "anedya-sdk",
   "description": "An SDK for interacting with Anedya nodes: fetching data, device status, and managing keys/values.",
  "version": "0.0.1",
  "author": "",
  "license": "ISC",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
   "files": [
