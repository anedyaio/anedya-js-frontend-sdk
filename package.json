{
  "name": "@anedyasystems/anedya-frontend-sdk",
  "description": "Official Anedya Frontend SDK for JavaScript and TypeScript. This SDK provides a comprehensive set of tools and functionalities to interact with Anedya's IoT platform, enabling developers to easily manage devices, access data, and execute commands in a seamless manner.",
  "homepage": "https://anedya.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/anedyaio/anedya-js-frontend-sdk.git"
  },
  "version": "0.1.0-beta.1",
  "author": "Anedya Systems",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "import": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "require": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "node tests/test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "node examples/application-example.js",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/cbor": "^5.0.1",
    "prettier": "^3.4.2",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "IoT",
    "Anedya",
    "SDK",
    "JavaScript",
    "TypeScript",
    "commands",
    "data-access",
    "cloud",
    "device-management",
    "API",
    "browser"
  ],
  "dependencies": {
    "cbor-x": "^1.6.4"
  },
  "overrides": {
    "human-id": "4.1.3"
  }
}